# CIUDAD SECRETA - Variables de entorno
# ===========================================================
# COPIAR este archivo a .env y completar los valores
# NUNCA subir .env a GitHub (ya está en .gitignore)

# Clave secreta para generar tokens HMAC-SHA256
# Generar con: openssl rand -hex 32
# IMPORTANTE: Mantener la misma clave para que los tokens funcionen
SECRET_KEY=TU_CLAVE_AQUI

# Entorno (development, production)
ENV=development

# Puerto del servidor
PORT=8000

# Base de datos (opcional, por defecto usa tokens.db local)
# DATABASE_URL=sqlite:///tokens.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ciudad_secreta

# Dominios permitidos (CORS)
ALLOWED_ORIGINS=http://localhost:3000,https://ciudadsecreta.app

# Modo debug
DEBUG=true
